# Digital Guardian — Environment Configuration
# Copy this file to .env and adjust values as needed.
# This file is safe to commit — no secrets here (local-only config).

APP_NAME="Digital Guardian API"
APP_VERSION="1.0.0"
DEBUG=True
HOST="127.0.0.1"
PORT=8000

# LLM — Groq API (free, zero disk space, llama3-70B)
# Get your free key at: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT=30